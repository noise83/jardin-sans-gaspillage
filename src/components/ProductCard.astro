---
import AffiliateButton from "./AffiliateButton.astro";
import affiliateConfig from "../data/affiliate-config.json";
import { getBestAffiliateUrl } from "../utils/affiliate";

interface Product {
  name: string;
  category: string;
  capacity: string;
  bestFor: string;
  positioning: string;
  priceRange: string;
  asin?: string;
  pros: string[];
  cons: string[];
  links?: {
    fallback?: string;
  };
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const affiliateUrl = getBestAffiliateUrl(product, affiliateConfig);
---

<article class="product-card">
  <p class="product-card__meta">{product.category} · {product.capacity}</p>
  <h3>{product.name}</h3>
  <p>{product.positioning}</p>
  <p><strong>Pour :</strong> {product.bestFor}</p>
  <p><strong>À vérifier :</strong> {product.cons.join(", ")}</p>
  <p><strong>Prix indicatif :</strong> {product.priceRange}</p>
  <AffiliateButton href={affiliateUrl} />
</article>
