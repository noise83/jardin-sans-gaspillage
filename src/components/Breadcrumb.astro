---
interface Item {
  label: string;
  href?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Fil d'Ariane">
  <ol>
    <li><a href="/">Accueil</a></li>
    {items.map((item) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
      </li>
    ))}
  </ol>
</nav>
