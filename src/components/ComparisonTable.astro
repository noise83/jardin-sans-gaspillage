---
import AffiliateButton from "./AffiliateButton.astro";
import affiliateConfig from "../data/affiliate-config.json";
import { getBestAffiliateUrl } from "../utils/affiliate";

interface Product {
  name: string;
  category: string;
  capacity: string;
  bestFor: string;
  positioning: string;
  priceRange: string;
  asin?: string;
  pros: string[];
  cons: string[];
  links?: {
    fallback?: string;
  };
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Produit</th>
        <th>Capacité</th>
        <th>Usage conseillé</th>
        <th>Points forts</th>
        <th>Limites</th>
        <th>Prix indicatif</th>
        <th>Offre</th>
      </tr>
    </thead>
    <tbody>
      {products.map((product) => (
        <tr>
          <td><strong>{product.name}</strong><br />{product.category}</td>
          <td>{product.capacity}</td>
          <td>{product.bestFor}</td>
          <td>{product.pros.join(", ")}</td>
          <td>{product.cons.join(", ")}</td>
          <td>{product.priceRange}</td>
          <td><AffiliateButton href={getBestAffiliateUrl(product, affiliateConfig)} /></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
