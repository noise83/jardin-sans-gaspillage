---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales du site Jardin Sans Gaspillage."
>
  <Breadcrumb items={[{ label: "Mentions légales" }]} />
  <section class="hero">
    <div class="container legal">
      <h1>Mentions légales</h1>
      <p>Jardin Sans Gaspillage est un site éditorial consacré à la récupération d'eau et au jardinage sobre.</p>
      <h2>Éditeur</h2>
      <p>Informations à compléter avant mise en production publique.</p>
      <h2>Hébergement</h2>
      <p>Informations à compléter selon l'hébergeur retenu.</p>
      <h2>Contact</h2>
      <p>Adresse de contact à compléter.</p>
    </div>
  </section>
</BaseLayout>
